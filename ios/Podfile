platform :ios, '13.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Carga dinámica nativa de los plugins de Flutter
  pod_helpers_path = File.join(File.dirname(__FILE__), '.symlinks', 'plugins', 'flutter_plugin_loader', 'ios', 'podhelper.rb')
  if File.exist?(pod_helpers_path)
    eval(File.read(pod_helpers_path), binding, pod_helpers_path)
  end
  
  flutter_ios_podfile_setup if respond_to?(:flutter_ios_podfile_setup)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target) if respond_to?(:flutter_additional_ios_build_settings)
    
    # Forzar a todas las dependencias OCR a compilar bajo la misma versión de iOS
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end
end
