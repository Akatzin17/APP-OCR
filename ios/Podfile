platform :ios, '13.0'

# Desactiva estadísticas de CocoaPods para acelerar la compilación
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :profile,
  'Release' => :release,
}

# Carga el entorno de exportación de Flutter (se generará automáticamente en el servidor)
require File.expand_path(File.join('..', 'Flutter', 'flutter_export_environment.sh'), __FILE__) rescue nil

# Obtiene la ruta del SDK de Flutter
def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'generated_xcode_build_settings.mgmt'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "generated_xcode_build_settings.mgmt must exist. If you're running pod install manually, make sure flutter pub get executes successfully first."
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in generated_xcode_build_settings.mgmt."
end

# Carga las herramientas de CocoaPods de Flutter
load File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Instala todas las dependencias del pubspec.yaml automáticamente
  flutter_install_all_ios_pods File.dirname(__FILE__)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    # Forzar iOS 13.0 para compatibilidad de dependencias
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end
end
