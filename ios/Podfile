platform :ios, '15.5'

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  legacy_settings_path = File.expand_path(File.join('..', 'Flutter', 'generated_xcode_build_settings.mgmt'), __FILE__)
  
  target_path = File.exist?(generated_xcode_build_settings_path) ? generated_xcode_build_settings_path : legacy_settings_path

  unless File.exist?(target_path)
    puts "Warning: No se encontró archivo de configuración en Flutter/. Usando fallback."
    return File.expand_path(File.join('..', '..', '..'), __FILE__)
  end

  File.foreach(target_path) do |line|
    matches = line.match(/FLUTTER_ROOT=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT no encontrado en el archivo de configuración nativo."
end

# Cargamos el helper nativo de Flutter
podhelper_path = File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
unless File.exist?(podhelper_path)
  podhelper_path = File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __FILE__)
end

if File.exist?(podhelper_path)
  load podhelper_path
else
  raise "No se pudo localizar podhelper.rb. Asegúrate de ejecutar flutter pub get."
end

target 'Runner' do
  # Mantenemos el enlace estático para evitar el error anterior de dependencias transitivas
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(__FILE__)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.5'
    end
  end
end
